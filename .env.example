# ============================================
# Ani-Go 环境变量配置模板
# 复制此文件为 .env 并填入你的配置
#   cp .env.example .env
# ============================================

# --- 必填 ---
# Mikan 个人 RSS 地址（带 Token）
MIKAN_RSS_URL=

# --- 下载器 ---
# qBittorrent (默认下载器)
QB_HOST=http://localhost:8081
QB_USER=
QB_PASS=

# --- 可选 ---
# 服务器端口 (默认 8080)
# PORT=8080

# 数据库文件路径
# DB_PATH=/data/ani-go.db

# 番剧根目录
# TV_BASE_PATH=/TV/Media/番剧

# Mikan 域名 (默认 mikanani.me)
# MIKAN_DOMAIN=mikanani.me

# --- AI 模块 (可选) ---
# AI_ENDPOINT=
# AI_API_KEY=
# AI_MODEL=gpt-4o-mini

# --- 元数据 (可选) ---
# TMDB_API_KEY=
# BGMTV_USER_TOKEN=
