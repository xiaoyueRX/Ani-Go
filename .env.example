# ============================================
# Ani-Go 环境变量配置模板
# 复制此文件为 .env 并填入你的配置
#   cp .env.example .env
# ============================================

# --- 必填 ---
# Mikan 个人 RSS 地址（带 Token）
MIKAN_RSS_URL=

# --- 下载器 ---
# 默认下载器: qbittorrent 或 transmission
# DEFAULT_DOWNLOADER=qbittorrent

# qBittorrent
# QB_HOST=http://localhost:8081
QB_USER=
QB_PASS=
# QB_CATEGORY=ani-go

# Transmission
# TR_HOST=http://localhost:9091
TR_USER=
TR_PASS=

# Aria2
# ARIA2_HOST=http://localhost:6800
# ARIA2_SECRET=your-rpc-secret

# --- 额外资源站 (可选，用于补全搜索) ---
# NYAA_DOMAIN=nyaa.si
# ACGRIP_DOMAIN=acg.rip
# ANIMETOSHO_DOMAIN=feed.animetosho.org

# --- 可选 ---
# 服务器端口 (默认 20001)
# PORT=20001

# 数据库文件路径
# DB_PATH=ani-go.db

# 番剧目录（默认相对路径，Docker 部署时用 /TV/... 覆盖）
# TV_BASE_PATH=./TV/番剧
# MOVIE_BASE_PATH=./TV/剧场版
# OVA_BASE_PATH=./TV/OVA

# Mikan 域名 (默认 mikanani.me)
# MIKAN_DOMAIN=mikanani.me

# Mikan 代理/镜像域名 (逗号分隔，GFW 下自动回退)
# MIKAN_PROXY_DOMAIN=
# MIKAN_MIRROR_DOMAINS=mikanani.me,mikanime.tv

# --- 通知 (可选，多平台推送) ---
# TELEGRAM_BOT_TOKEN=xxx
# TELEGRAM_CHAT_ID=xxx
# DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx/xxx
# WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx

# QQ (NapCat / go-cqhttp / Lagrange / LLOneBot — OneBot 协议)
# ONEBOT_HOST=http://localhost:3000
# ONEBOT_TOKEN=xxx
# ONEBOT_USER_ID=123456789    # 私聊目标 QQ 号
# ONEBOT_GROUP_ID=987654321   # 群聊目标群号

# Slack
# SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/xxx/xxx

# Matrix (Element)
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_TOKEN=syt_xxx
# MATRIX_ROOM_ID=!abc123:matrix.org

# 邮件 (SMTP)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USERNAME=xxx@gmail.com
# EMAIL_PASSWORD=xxx
# EMAIL_FROM=xxx@gmail.com
# EMAIL_TO=admin@example.com

# LINE (LINE Messaging API)
# LINE_CHANNEL_TOKEN=xxx
# LINE_USER_ID=Uxxx

# WhatsApp (Meta Cloud API)
# WHATSAPP_PHONE_ID=123456789
# WHATSAPP_TOKEN=xxx
# WHATSAPP_TO=8613800138000

# Server酱 (微信推送)
# SERVERCHAN_KEY=xxx

# Bark (iOS 推送)
# BARK_DEVICE_KEY=xxx

# Pushover
# PUSHOVER_TOKEN=xxx
# PUSHOVER_USER=xxx

# Gotify (自托管)
# GOTIFY_URL=https://gotify.example.com
# GOTIFY_TOKEN=xxx

# ntfy (自托管)
# NTFY_URL=https://ntfy.sh/mytopic

# --- AI 模块 (可选) ---
# AI_PROTOCOL=auto          # 协议: openai / google / anthropic / ollama / auto（默认自动检测）
# AI_ENDPOINT=              # 自定义 API 端点（openai/ollama 用）
# AI_API_KEY=               # API 密钥（openai/anthropic 用）
# AI_MODEL=                 # 模型名（不设则使用默认值）

# OpenAI / 兼容协议 (DeepSeek/Groq/通义千问/智谱 等)
# AI_PROTOCOL=openai
# AI_ENDPOINT=https://api.openai.com/v1/chat/completions
# AI_API_KEY=sk-xxx
# AI_MODEL=gpt-4o-mini

# Google (Gemini)
# AI_PROTOCOL=google
# GEMINI_API_KEY=xxx
# AI_MODEL=gemini-2.0-flash

# Anthropic (Claude)
# AI_PROTOCOL=anthropic
# CLAUDE_API_KEY=sk-ant-xxx
# AI_MODEL=claude-haiku-4-5-20251001

# Ollama (本地部署)
# AI_PROTOCOL=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# --- 元数据 (可选) ---
# TMDB_API_KEY=
# TMDB_MIRROR_DOMAINS=
# BGMTV_USER_TOKEN=
# BGMTV_MIRROR_DOMAINS=api.bgm.tv,api.bangumi.tv,api.chii.in

# --- GitHub 镜像 (GFW 环境) ---
# 国内环境建议设置: export GOPROXY=https://goproxy.cn,direct
